{
  "expo": {
    "name": "NicAntojo",
    "slug": "nicantojo",
    "scheme": "nicantojo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/nicantojo-icon.png",
    "userInterfaceStyle": "automatic",
    "updates": {
      "enabled": false
    },
    "ios": {
      "bundleIdentifier": "com.nicantojo.app",
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.nicantojo.app",
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "nicantojo"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAS3gZFkeUk4fSKK9RZX0m8s58bvpJjI7Q"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E63946",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": false
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6e59d45c-c4a2-4c64-a955-da17cb2454fb"
      }
    }
  }
}